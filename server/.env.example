# ── Copy this file to server/.env and fill in your values ──────────────
#
# EASIEST (prototype): just set GEMINI_API_KEY from https://aistudio.google.com
# → no GCP roles, no bucket needed. If GEMINI_API_KEY is set it takes priority.
GEMINI_API_KEY=

# ── OR: Vertex AI path (uses your GCP credit) — fill the block below ────
# Your GCP project ID (NOT the project name/number)
GCP_PROJECT_ID=your-gcp-project-id

# Vertex AI region. us-central1 is the safest default for Gemini.
GCP_LOCATION=us-central1

# A Cloud Storage bucket you created to hold recordings + analyses
GCS_BUCKET=rangle-call-recordings

# Path to the service-account JSON key file you downloaded.
# Place the file in server/ and DO NOT commit it (it's git-ignored).
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Gemini model. 2.5-flash = fast + cheap; 2.5-pro = deeper analysis.
GEMINI_MODEL=gemini-2.5-flash

# Port the API listens on
PORT=8787

# Frontend origin(s) allowed to call this API (comma-separated)
ALLOWED_ORIGIN=http://localhost:5173
